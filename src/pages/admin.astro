---
import "@/styles/global.css";
import { Dashboard } from "@/components/Dashboard";
import { env } from "cloudflare:workers";

// Basic protection is assumed via Cloudflare Access at edge, so no auth logic here.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>roli.to - Links</title>
  </head>
  <body
    class="bg-background text-foreground min-h-screen antialiased selection:bg-primary/30 dark"
  >
    <!-- Using dark mode by default for premium feel -->
    <Dashboard client:load apiSecret={env.API_SECRET} />
  </body>
</html>
