{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "link-tracker",
  "compatibility_date": "2024-04-05",
  "routes": [
    {
      "pattern": "link.roli.to",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "link-tracker-db",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "./migrations"
    }
  ],
  "observability": {
    "enabled": true
  }
}